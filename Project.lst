 00000040  6A 04	   *	    push   +000000004h
 00000042  FF 35 00000000 E *	    push   hHeap
 00000048  E8 00000000 E   *	    call   HeapAlloc
 0000004D  8B C8			mov ecx, eax ; // Move the memory address to ecx so it can function as a "this" pointer
					INVOKE init_neon_game_manager
 0000004F  E8 FFFFFFAC	   *	    call   init_neon_game_manager

					ret ; // Return with the address of the memory block in HeapAlloc
 00000054  59		   *	    pop    ecx
 00000055  C3		   *	    ret    00000h
