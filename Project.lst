 00000000			init_renderable_component PROC PUBLIC USES esi, visible : DWORD, layer : DWORD
					; // Parent constructor
 00000000  55		   *	    push   ebp
 00000001  8B EC	   *	    mov    ebp, esp
 00000003  56		   *	    push   esi
					INVOKE init_component
 00000004  E8 00000000 E   *	    call   init_component
 00000009  C7 01 00000004		mov (Component PTR [ecx]).componentType, RENDERABLE_COMPONENT_ID

					; // Height & Width
 0000000F  8B 75 08			mov esi, visible
 00000012  89 71 08			mov (RenderableComponent PTR [ecx]).visible, esi
 00000015  8B 75 0C			mov esi, layer
 00000018  89 71 0C			mov (RenderableComponent PTR [ecx]).layer, esi

 0000001B  8B C1			mov eax, ecx
					ret
 0000001D  5E		   *	    pop    esi
 0000001E  C9		   *	    leave  
 0000001F  C2 0008	   *	    ret    00008h
 00000022			init_renderable_component ENDP

				END 
