					INVOKE HeapFree, hHeap, 0, ecx
 00000013  51		   *	    push   ecx
 00000014  6A 00	   *	    push   +000000000h
 00000016  FF 35 00000000 E *	    push   hHeap
 0000001C  E8 00000000 E   *	    call   HeapFree
					ret
 00000021  5E		   *	    pop    esi
 00000022  C3		   *	    ret    00000h
 00000023			free_vector ENDP

