 0000000B  8D 4E 04			lea ecx, (GameObject PTR [esi]).components
					
 0000000E  8B 45 0C			mov eax, pComponent
					INVOKE push_back, eax
 00000011  50		   *	    push   eax
 00000012  E8 00000000 E   *	    call   push_back

					ret
 00000017  5F		   *	    pop    edi
 00000018  5E		   *	    pop    esi
 00000019  59		   *	    pop    ecx
 0000001A  5B		   *	    pop    ebx
 0000001B  58		   *	    pop    eax
 0000001C  C9		   *	    leave  
 0000001D  C2 0008	   *	    ret    00008h
 00000020			add_component ENDP

				; // ----------------------------------
				; // check_rect_collision
				; // Returns 1 if the given RectComponent/TransformComponent pairs are overlapping
				; // with each other and 0 if not. If HitboxComponents are added to the engine
				; // later, then this function will become obsolete.
				; // ----------------------------------
 00000020			check_rect_collision PROC PUBLIC USES eax ebx ecx esi edi, pRect1 : DWORD, pTrans1 : DWORD, pRect2 : DWORD, pTrans2
					LOCAL x1 : DWORD, y1 : DWORD, w1 : DWORD, h1 : DWORD
					LOCAL x2 : DWORD, y2 : DWORD, w2 : DWORD, h2 : DWORD

					; // Initialize local variables
 00000020  55		   *	    push   ebp
 00000021  8B EC	   *	    mov    ebp, esp
 00000023  83 C4 E0	   *	    add    esp, 0FFFFFFE0h
 00000026  50		   *	    push   eax
 00000027  53		   *	    push   ebx
 00000028  51		   *	    push   ecx
 00000029  56		   *	    push   esi
 0000002A  57		   *	    push   edi
 0000002B  8B 75 0C			mov esi, pTrans1 
 0000002E  8B 7E 08			mov edi, (TransformComponent PTR [esi]).x
 00000031  89 7D FC			mov x1, edi
 00000034  8B 7E 0C			mov edi, (TransformComponent PTR [esi]).y
 00000037  89 7D F8			mov y1, edi

 0000003A  8B 75 08			mov esi, pRect1 
 0000003D  8B 7E 08			mov edi, (RectComponent PTR [esi]).h
 00000040  89 7D F0			mov h1, edi
 00000043  8B 7E 0C			mov edi, (RectComponent PTR [esi]).w
 00000046  89 7D F4			mov w1, edi

 00000049  8B 75 14			mov esi, pTrans2 
 0000004C  8B 7E 08			mov edi, (TransformComponent PTR [esi]).x
 0000004F  89 7D EC			mov x2, edi
 00000052  8B 7E 0C			mov edi, (TransformComponent PTR [esi]).y
 00000055  89 7D E8			mov y2, edi

 00000058  8B 75 10			mov esi, pRect2 
 0000005B  8B 7E 08			mov edi, (RectComponent PTR [esi]).h
 0000005E  89 7D E0			mov h2, edi
 00000061  8B 7E 0C			mov edi, (RectComponent PTR [esi]).w
 00000064  89 7D E4			mov w2, edi
					ret
 00000067  5F		   *	    pop    edi
 00000068  5E		   *	    pop    esi
 00000069  59		   *	    pop    ecx
 0000006A  5B		   *	    pop    ebx
 0000006B  58		   *	    pop    eax
 0000006C  C9		   *	    leave  
 0000006D  C2 0010	   *	    ret    00010h
 00000070			check_rect_collision ENDP

				; // ********************************************
				; // Constructor Methods
