				INCLUDE input_manager.inc
			      C ; // ==================================
			      C ; // input_manager.inc
			      C ; // ----------------------------------
			      C ; // The input manager is responsible for determining
			      C ; // which keys are currently pressed and providing
			      C ; // a convenient method for other files to determine
			      C ; // the currently pressed keys. This should be
			      C ; // updated on a by-frame basis by a scene.
			      C ; // ==================================
			      C 
			      C IFNDEF INPUT_MANAGER_INC
 = 00000001		      C INPUT_MANAGER_INC EQU 1
			      C 
			      C VK_CODE typedef BYTE 
			      C 
			      C ; // Win32 virtual key codes taken from learn.microsoft.com/en-us/windows/win32/inputdev/virtual-key-codes
 = 00000025		      C VK_LEFT		=	025h
 = 00000026		      C VK_UP		=	026h
 = 00000027		      C VK_RIGHT	=	027h
 = 00000028		      C VK_DOWN		=	028h
			      C 
 = 000000CB		      C VK_GAMEPAD_DPAD_UP		= 0CBh
 = 000000CC		      C VK_GAMEPAD_DPAD_DOWN	= 0CCh
			      C 
 = 000000D3		      C VK_GAMEPAD_LEFT_THUMBSTICK_UP	= 0D3h	
 = 000000D4		      C VK_GAMEPAD_LEFT_THUMBSTICK_DOWN = 0D4h
			      C 
			      C updateInput PROTO
			      C isKeyPressed PROTO vkCode: VK_CODE
			      C isKeyJustPressed PROTO vkCode: VK_CODE
			      C 
			      C ENDIF
			      C 

 00000000			.code
				; // ********************************************
				; // Constructor Methods
				; // ********************************************

				; // ----------------------------------
				; // init_scene
				; // Initializes memory with the contents of a Scene
				; // 
				; // Register Parameters: 
				; //	ecx - THIS pointer
				; // ----------------------------------
 00000000			init_scene PROC PUBLIC USES esi, maxGameObjects : DWORD
 00000000  55		   *	    push   ebp
 00000001  8B EC	   *	    mov    ebp, esp
 00000003  56		   *	    push   esi
 00000004  8B F1			mov esi, ecx ; // Save off my THIS pointer in esi

 00000006  8D 0E			lea ecx, (Scene PTR [esi]).camera
					INVOKE init_camera, 0, 0
 00000008  6A 00	   *	    push   +000000000h
 0000000A  6A 00	   *	    push   +000000000h
 0000000C  E8 00000000 E   *	    call   init_camera

 00000011  8D 4E 10			lea ecx, (Scene PTR [esi]).gameObjects
					INVOKE init_unordered_vector, maxGameObjects
 00000014  FF 75 08	   *	    push   dword  ptr ss:[ebp]+000000008h
 00000017  E8 00000000 E   *	    call   init_unordered_vector

 0000001C  8D 4E 1C			lea ecx, (Scene PTR [esi]).startQueue
					INVOKE init_unordered_vector, maxGameObjects
 0000001F  FF 75 08	   *	    push   dword  ptr ss:[ebp]+000000008h
 00000022  E8 00000000 E   *	    call   init_unordered_vector

 00000027  8D 4E 28			lea ecx, (Scene PTR [esi]).freeQueue
					INVOKE init_unordered_vector, maxGameObjects
 0000002A  FF 75 08	   *	    push   dword  ptr ss:[ebp]+000000008h
 0000002D  E8 00000000 E   *	    call   init_unordered_vector
					
 00000032  8D 4E 34			lea ecx, (Scene PTR [esi]).renderCommands
					INVOKE init_unordered_vector, maxGameObjects
 00000035  FF 75 08	   *	    push   dword  ptr ss:[ebp]+000000008h
 00000038  E8 00000000 E   *	    call   init_unordered_vector

