				; // ----------------------------------
				; // init_game_object
				; // Initializes memory with the contents of a GameObject
				; // 
				; // Register Parameters: 
				; //	ecx - THIS pointer
				; // ----------------------------------
 00000070			init_game_object PROC PUBLIC USES esi ebx edx, maxComponents : DWORD
					local pThis: DWORD
 00000070  55		   *	    push   ebp
 00000071  8B EC	   *	    mov    ebp, esp
 00000073  83 C4 FC	   *	    add    esp, 0FFFFFFFCh
 00000076  56		   *	    push   esi
 00000077  53		   *	    push   ebx
 00000078  52		   *	    push   edx
 00000079  89 4D FC			mov pThis, ecx
 0000007C  C7 01 00000000		mov (GameObject PTR [ecx]).gameObjectType, DEFAULT_GAME_OBJECT_ID
 00000082  C7 41 18			mov (GameObject PTR [ecx]).awaitingFree, 0 ; // Set awaiting free to false (0)
	   00000000
 00000089  C7 41 14			mov (GameObject PTR [ecx]).pParentScene, 0 ; // Set parent to a NULL pointer
	   00000000

					; // Set up vTable
 00000090  C7 41 10			mov (GameObject PTR [ecx]).pVt, OFFSET GAMEOBJECT_VTABLE
	   00000000 R

					; // Now set up the component pointer table
 00000097  8D 49 04			lea ecx, (GameObject PTR [ecx]).components
					INVOKE init_unordered_vector, maxComponents
 0000009A  FF 75 08	   *	    push   dword  ptr ss:[ebp]+000000008h
 0000009D  E8 00000000 E   *	    call   init_unordered_vector

 000000A2  8B 4D FC			mov ecx, pThis
 000000A5  8B C1			mov eax, ecx ; // Return the this pointer

					ret
 000000A7  5A		   *	    pop    edx
 000000A8  5B		   *	    pop    ebx
 000000A9  5E		   *	    pop    esi
 000000AA  C9		   *	    leave  
 000000AB  C2 0004	   *	    ret    00004h
 000000AE			init_game_object ENDP

				; // ----------------------------------
				; // new_game_object
				; // Reserves heap space for the Object with parameters calls the initializer method
				; // ----------------------------------
 000000AE			new_game_object PROC PUBLIC USES ecx, maxComponents : DWORD
 000000AE  55		   *	    push   ebp
 000000AF  8B EC	   *	    mov    ebp, esp
 000000B1  51		   *	    push   ecx
					INVOKE HeapAlloc, hHeap, HEAP_GENERATE_EXCEPTIONS, SIZEOF GameObject
 000000B2  6A 1C	   *	    push   +00000001Ch
 000000B4  6A 04	   *	    push   +000000004h
 000000B6  FF 35 00000000 E *	    push   hHeap
 000000BC  E8 00000000 E   *	    call   HeapAlloc
 000000C1  8B C8			mov ecx, eax ; // Move the memory address to ecx so it can function as a "this" pointer
					INVOKE init_game_object, maxComponents
 000000C3  FF 75 08	   *	    push   dword  ptr ss:[ebp]+000000008h
 000000C6  E8 FFFFFFA5	   *	    call   init_game_object

					ret ; // Return with the address of the memory block in HeapAlloc
 000000CB  59		   *	    pop    ecx
 000000CC  C9		   *	    leave  
 000000CD  C2 0004	   *	    ret    00004h
 000000D0			new_game_object ENDP

				; // ----------------------------------
				; // free_game_object
				; // Convenient method for freeing a GameObject
				; //
				; // Register Parameters: 
				; //	ecx - THIS pointer
