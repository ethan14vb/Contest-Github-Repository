				; // ----------------------------------
				; // transition_state
				; // Randomly decides what the next state will be
				; // 
				; // Register Parameters: 
				; //	ecx - THIS pointer
				; // ----------------------------------
 00000056			transition_state PROC USES eax ebx edx esi edi
 00000056  50		   *	    push   eax
 00000057  53		   *	    push   ebx
 00000058  52		   *	    push   edx
 00000059  56		   *	    push   esi
 0000005A  57		   *	    push   edi
 0000005B  B8 00000003			mov eax, 3
					INVOKE RandomRange
 00000060  E8 00000000 E   *	    call   RandomRange

					.IF eax == DEFAULT_STATE_ENUM
 00000065  0B C0	   *	    or	eax, eax
 00000067  75 26	   *	    jne    @C0001
 00000069  C7 41 20				mov (NeonGameManager PTR [ecx]).state, DEFAULT_STATE_ENUM
	   00000000
 00000070  C7 41 1C				mov (NeonGameManager PTR [ecx]).timer, 0
	   00000000
						
						; // Get a random number of objects in this scene
 00000077  B8 00000004				mov eax, defaultStateObjectMax
 0000007C  83 E8 02				sub eax, defaultStateObjectMin
						
