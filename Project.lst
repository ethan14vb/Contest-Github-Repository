				; // ----------------------------------
				; // add_component
				; // Initializes memory with the contents of a GameObject
				; // ----------------------------------
 00000000			add_component PROC PUBLIC USES eax ebx ecx esi edi, pGameObject: DWORD, pComponent: DWORD
 00000000  55		   *	    push   ebp
 00000001  8B EC	   *	    mov    ebp, esp
 00000003  50		   *	    push   eax
 00000004  53		   *	    push   ebx
 00000005  51		   *	    push   ecx
 00000006  56		   *	    push   esi
 00000007  57		   *	    push   edi
 00000008  8B 75 08			mov esi, pGameObject
 0000000B  8D 4E 04			lea ecx, (GameObject PTR [esi]).components
					
 0000000E  8B 45 0C			mov eax, pComponent
					INVOKE push_back, eax
 00000011  50		   *	    push   eax
 00000012  E8 00000000 E   *	    call   push_back

					ret
 00000017  5F		   *	    pop    edi
 00000018  5E		   *	    pop    esi
 00000019  59		   *	    pop    ecx
 0000001A  5B		   *	    pop    ebx
 0000001B  58		   *	    pop    eax
 0000001C  C9		   *	    leave  
 0000001D  C2 0008	   *	    ret    00008h
 00000020			add_component ENDP

				; // ----------------------------------
				; // check_rect_collision
				; // Returns 1 if the given RectComponent/TransformComponent pairs are overlapping
				; // with each other and 0 if not. If HitboxComponents are added to the engine
				; // later, then this function will become obsolete.
				; // ----------------------------------
 00000020			check_rect_collision PROC PUBLIC USES ebx ecx esi edi, pRect1 : DWORD, pTrans1 : DWORD, pRect2 : DWORD, pTrans2 : DWORD
					LOCAL x1 : DWORD, y1 : DWORD, w1 : DWORD, h1 : DWORD
					LOCAL x2 : DWORD, y2 : DWORD, w2 : DWORD, h2 : DWORD

					; // Initialize local variables
 00000020  55		   *	    push   ebp
 00000021  8B EC	   *	    mov    ebp, esp
 00000023  83 C4 E0	   *	    add    esp, 0FFFFFFE0h
 00000026  53		   *	    push   ebx
 00000027  51		   *	    push   ecx
 00000028  56		   *	    push   esi
 00000029  57		   *	    push   edi
 0000002A  8B 75 0C			mov esi, pTrans1 
 0000002D  8B 7E 08			mov edi, (TransformComponent PTR [esi]).x
 00000030  89 7D FC			mov x1, edi
 00000033  8B 7E 0C			mov edi, (TransformComponent PTR [esi]).y
 00000036  89 7D F8			mov y1, edi

 00000039  8B 75 08			mov esi, pRect1 
 0000003C  8B 7E 08			mov edi, (RectComponent PTR [esi]).h
 0000003F  89 7D F0			mov h1, edi
 00000042  8B 7E 0C			mov edi, (RectComponent PTR [esi]).w
 00000045  89 7D F4			mov w1, edi

 00000048  8B 75 14			mov esi, pTrans2 
 0000004B  8B 7E 08			mov edi, (TransformComponent PTR [esi]).x
 0000004E  89 7D EC			mov x2, edi
 00000051  8B 7E 0C			mov edi, (TransformComponent PTR [esi]).y
 00000054  89 7D E8			mov y2, edi

 00000057  8B 75 10			mov esi, pRect2 
 0000005A  8B 7E 08			mov edi, (RectComponent PTR [esi]).h
 0000005D  89 7D E0			mov h2, edi
 00000060  8B 7E 0C			mov edi, (RectComponent PTR [esi]).w
 00000063  89 7D E4			mov w2, edi

					; // If obj1 left >= obj2 right -> No Collision
 00000066  8B 45 FC			mov eax, x1
 00000069  8B 4D EC			mov ecx, x2
 0000006C  03 4D E4			add ecx, w2
 0000006F  3B C1			cmp eax, ecx
 00000071  7D 2E			jge no_collision

					; // If obj1 right <= obj2 left) -> No Collision
 00000073  8B 45 FC			mov eax, x1
 00000076  03 45 F4			add eax, w1
 00000079  8B 4D EC			mov ecx, x2
 0000007C  3B C1			cmp eax, ecx
 0000007E  7E 21			jle no_collision

					; // If obj1 top >= obj2 bottom -> No Collision
 00000080  8B 45 F8			mov eax, y1
 00000083  8B 4D E8			mov ecx, y2
 00000086  03 4D E0			add ecx, h2
 00000089  3B C1			cmp eax, ecx
 0000008B  7D 14			jge no_collision
				
					; // If obj1 bottom <= obj2 top -> No Collision
 0000008D  8B 45 F8			mov eax, y1
 00000090  03 45 F0			add eax, h1
 00000093  8B 4D E8			mov ecx, y2
 00000096  3B C1			cmp eax, ecx
 00000098  7E 07			jle no_collision

					; // All checks passed, there must be a collision
 0000009A  B8 00000001			mov eax, 1
 0000009F  EB 05			jmp check_rect_collision_exit

 000000A1			no_collision:
 000000A1  B8 00000000			mov eax, 0
 000000A6			check_rect_collision_exit:
					ret
 000000A6  5F		   *	    pop    edi
 000000A7  5E		   *	    pop    esi
 000000A8  59		   *	    pop    ecx
 000000A9  5B		   *	    pop    ebx
 000000AA  C9		   *	    leave  
 000000AB  C2 0010	   *	    ret    00010h
 000000AE			check_rect_collision ENDP

				; // ********************************************
				; // Constructor Methods
				; // ********************************************

				; // ----------------------------------
				; // init_game_object
				; // Initializes memory with the contents of a GameObject
				; // 
				; // Register Parameters: 
				; //	ecx - THIS pointer
				; // ----------------------------------
 000000AE			init_game_object PROC PUBLIC USES esi ebx edx, maxComponents : DWORD
					local pThis: DWORD
 000000AE  55		   *	    push   ebp
 000000AF  8B EC	   *	    mov    ebp, esp
 000000B1  83 C4 FC	   *	    add    esp, 0FFFFFFFCh
 000000B4  56		   *	    push   esi
 000000B5  53		   *	    push   ebx
 000000B6  52		   *	    push   edx
 000000B7  89 4D FC			mov pThis, ecx
 000000BA  C7 01 00000000		mov (GameObject PTR [ecx]).gameObjectType, DEFAULT_GAME_OBJECT_ID
 000000C0  C7 41 18			mov (GameObject PTR [ecx]).awaitingFree, 0 ; // Set awaiting free to false (0)
	   00000000
 000000C7  C7 41 14			mov (GameObject PTR [ecx]).pParentScene, 0 ; // Set parent to a NULL pointer
	   00000000

					; // Set up vTable
 000000CE  C7 41 10			mov (GameObject PTR [ecx]).pVt, OFFSET GAMEOBJECT_VTABLE
	   00000000 R

					; // Now set up the component pointer table
 000000D5  8D 49 04			lea ecx, (GameObject PTR [ecx]).components
					INVOKE init_unordered_vector, maxComponents
 000000D8  FF 75 08	   *	    push   dword  ptr ss:[ebp]+000000008h
 000000DB  E8 00000000 E   *	    call   init_unordered_vector

 000000E0  8B 4D FC			mov ecx, pThis
 000000E3  8B C1			mov eax, ecx ; // Return the this pointer

					ret
 000000E5  5A		   *	    pop    edx
 000000E6  5B		   *	    pop    ebx
 000000E7  5E		   *	    pop    esi
 000000E8  C9		   *	    leave  
 000000E9  C2 0004	   *	    ret    00004h
 000000EC			init_game_object ENDP

				; // ----------------------------------
				; // new_game_object
				; // Reserves heap space for the Object with parameters calls the initializer method
				; // ----------------------------------
 000000EC			new_game_object PROC PUBLIC USES ecx, maxComponents : DWORD
 000000EC  55		   *	    push   ebp
 000000ED  8B EC	   *	    mov    ebp, esp
 000000EF  51		   *	    push   ecx
					INVOKE HeapAlloc, hHeap, HEAP_GENERATE_EXCEPTIONS, SIZEOF GameObject
 000000F0  6A 1C	   *	    push   +00000001Ch
 000000F2  6A 04	   *	    push   +000000004h
 000000F4  FF 35 00000000 E *	    push   hHeap
 000000FA  E8 00000000 E   *	    call   HeapAlloc
 000000FF  8B C8			mov ecx, eax ; // Move the memory address to ecx so it can function as a "this" pointer
					INVOKE init_game_object, maxComponents
 00000101  FF 75 08	   *	    push   dword  ptr ss:[ebp]+000000008h
 00000104  E8 FFFFFFA5	   *	    call   init_game_object

					ret ; // Return with the address of the memory block in HeapAlloc
 00000109  59		   *	    pop    ecx
 0000010A  C9		   *	    leave  
 0000010B  C2 0004	   *	    ret    00004h
 0000010E			new_game_object ENDP

				; // ----------------------------------
				; // free_game_object
				; // Convenient method for freeing a GameObject
				; //
				; // Register Parameters: 
				; //	ecx - THIS pointer
				; // ----------------------------------
 0000010E			free_game_object PROC PUBLIC USES eax esi ebx
					; // Destruct the components
 0000010E  50		   *	    push   eax
 0000010F  56		   *	    push   esi
 00000110  53		   *	    push   ebx
