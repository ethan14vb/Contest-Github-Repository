			      C RenderCommand ENDS
			      C 
			      C ; // Constructor methods
			      C init_render_command PROTO rcType: RC_ENUM, pTransform : DWORD, pRenderable : DWORD
			      C new_render_command PROTO rcType: RC_ENUM, pTransform: DWORD, pRenderable: DWORD
