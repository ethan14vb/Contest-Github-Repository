				; // ==================================
				; // input_manager.asm
				; // ----------------------------------
				; // The input manager is responsible for determining
				; // which keys are currently pressed and providing
				; // a convenient method for other files to determine
				; // the currently pressed keys. This should be
				; // updated on a by-frame basis by a scene.
				; // ==================================

				INCLUDE default_header.inc
			      C .386
			      C .model flat, stdcall
			      C option casemap : none
			      C .stack 4096
			      C OPTION PROC : PRIVATE
			      C 
				INCLUDE input_manager.inc
			      C ; // ==================================
			      C ; // input_manager.inc
			      C ; // ----------------------------------
			      C ; // The input manager is responsible for determining
			      C ; // which keys are currently pressed and providing
			      C ; // a convenient method for other files to determine
			      C ; // the currently pressed keys. This should be
			      C ; // updated on a by-frame basis by a scene.
			      C ; // ==================================
			      C 
			      C IFNDEF INPUT_MANAGER_INC
 = 00000001		      C INPUT_MANAGER_INC EQU 1
			      C 
			      C updateInput PROTO
			      C isKeyPressed PROTO vkCode: DWORD
			      C isKeyJustPressed PROTO vkCode: DWORD
			      C 
			      C ENDIF
			      C 

				GetKeyboardState PROTO pBuffer : DWORD

 00000000			.data
				; // Holds the data for all 256 virtual keys and whether they are currently pressed
 00000000  00000100 [		curInputBuffer BYTE 256 DUP(0)
	    00
	   ]

				; // Holds the data for the previous input buffer for determining if a key was just pressed
 00000100  00000100 [		prevInputBuffer BYTE 256 DUP(0)
	    00
	   ]

 00000000			.code
				; // ----------------------------------
				; // updateInput
				; // This should be called every frame by Scene. Updates the 
				; // current and previous buffers.
				; // ----------------------------------
 00000000			updateInput PROC PUBLIC USES ebx ecx edx esi edi
					; // Copy the current buffer to the previous
 00000000  53		   *	    push   ebx
 00000001  51		   *	    push   ecx
 00000002  52		   *	    push   edx
 00000003  56		   *	    push   esi
 00000004  57		   *	    push   edi
 00000005  FC				cld
 00000006  BE 00000000 R	    mov esi, OFFSET curInputBuffer
 0000000B  BF 00000100 R	    mov edi, OFFSET prevInputBuffer
 00000010  B9 00000100		    mov ecx, 256
 00000015  F3/ A4		    rep movsb

					; // Get the current input state
					; // This is a Win32 API function that was added to the program before we learned about it
					; // during class. This function was used because it provided the greatest flexibility
					; // compared to the Irvine32 libraries for this engine.
					; // Documentation used: learn.microsoft.com/en-us/windows/win32/api/winuser/nf-winuser-getkeyboardstate
					INVOKE GetKeyboardState, OFFSET curInputBuffer
 00000017  68 00000000 R   *	    push   dword  ptr OFFSET FLAT: curInputBuffer
 0000001C  E8 00000000 E   *	    call   GetKeyboardState

					ret
 00000021  5F		   *	    pop    edi
 00000022  5E		   *	    pop    esi
 00000023  5A		   *	    pop    edx
 00000024  59		   *	    pop    ecx
 00000025  5B		   *	    pop    ebx
 00000026  C3		   *	    ret    00000h
 00000027			updateInput ENDP

				; // ----------------------------------
				; // isKeyPressed
				; // Returns 1 if a key is currently pressed and 0 if a key
				; // is not currently pressed this frame.
				; // ----------------------------------
 00000027			isKeyPressed PROC PUBLIC, vkCode: DWORD
 00000027  55		   *	    push   ebp
 00000028  8B EC	   *	    mov    ebp, esp
 0000002A  8A 85 00000008 R		mov al, [curInputBuffer + vkCode]
 00000030  A8 80			test al, 80h ; // Test the high bit
 00000032  74 07			jz keyNotPressed

					; // Key is pressed, return 1
 00000034  B8 00000001			mov eax, 1
 00000039  EB 05			jmp exitIsKeyPressed

 0000003B			keyNotPressed:
 0000003B  B8 00000000			mov eax, 0

 00000040			exitIsKeyPressed:
					ret
 00000040  C9		   *	    leave  
 00000041  C2 0004	   *	    ret    00004h
 00000044			isKeyPressed ENDP

				; // ----------------------------------
				; // isKeyJustPressed
				; // Returns 1 if a key is just pressed this frame and 0 if the key
				; // was not just pressed this frame.
				; // ----------------------------------
 00000044			isKeyJustPressed PROC PUBLIC USES ebx, vkCode: DWORD
 00000044  55		   *	    push   ebp
 00000045  8B EC	   *	    mov    ebp, esp
 00000047  53		   *	    push   ebx
 00000048  8A 85 00000008 R		mov al, [curInputBuffer + vkCode]
 0000004E  8A 9D 00000108 R		mov bl, [prevInputBuffer + vkCode]

 00000054  A8 80			test al, 80h ; // Test the high bit
 00000056  74 0C			jz keyNotJustPressed
					
					; // Test if the key was also pressed last frame
 00000058  F6 C3 80			test bl, 80h
 0000005B  75 07			jnz keyNotJustPressed

					; // Key was just pressed, return 1
 0000005D  B8 00000001			mov eax, 1
 00000062  EB 05			jmp exitIsKeyJustPressed
						
 00000064			keyNotJustPressed:
 00000064  B8 00000000			mov eax, 0
 00000069			exitIsKeyJustPressed:
					ret
 00000069  5B		   *	    pop    ebx
 0000006A  C9		   *	    leave  
 0000006B  C2 0004	   *	    ret    00004h
 0000006E			isKeyJustPressed ENDP

				END
