				; // ==================================
				; // heap_functions_test.asm
				; // ----------------------------------
				; // For testing heap functionality
				; //
				; // Usage: 
				; //	Exclude main.asm from the project and instead include this file, then build,
				; // run, and feel free to debug and test.
				; // ==================================

				INCLUDE default_header.inc
			      C .386
			      C .model flat, stdcall
			      C option casemap : none
			      C .stack 4096
			      C OPTION PROC : PRIVATE
			      C 
				INCLUDE heap_functions.inc
			      C ; // ==================================
			      C ; // heap_functions.inc
			      C ; // ----------------------------------
			      C ; // Functions used for dynamic memory management. This file was
			      C ; // added before we learned about heap memory management in class
			      C ; // so we could have easy memory management. My resource for this 
			      C ; // was the windows API reference and the class ch11 slides.
			      C ; // ==================================
			      C 
			      C IFNDEF HEAP_FUNCTIONS_INC
 = 00000001		      C HEAP_FUNCTIONS_INC EQU 1
			      C 
			      C INCLUDELIB kernel32.lib
			      C 
			      C ; // Constants
 = 00000008		      C HEAP_ZERO_MEMORY          equ 00000008h
 = 00000004		      C HEAP_GENERATE_EXCEPTIONS  equ 00000004h
 = 00000001		      C HEAP_NO_SERIALIZE         equ 00000001h
			      C 
 = 00000000		      C NULL   EQU 0
			      C 
			      C ; // Types
			      C HANDLE TYPEDEF DWORD
			      C 
			      C ; // Protos
			      C GetProcessHeap	PROTO
			      C HeapAlloc		PROTO,	hHeap:DWORD, dwFlags:DWORD, dwBytes:DWORD
			      C HeapFree		PROTO,	hHeap:DWORD, dwFlags:DWORD, lpMem:DWORD
			      C HeapReAlloc		PROTO,	hHeap:DWORD, dwFlags:DWORD, lpMem:DWORD,	dwBytes:DWORD
			      C 
			      C ENDIF
			      C 

				ExitProcess PROTO : DWORD

 00000000			.data
 00000000 00000000		hHeap HANDLE ?
 00000004 00000000		pMemory DWORD ?

 00000000			.code
 00000000			main PROC PUBLIC
					; // Get heap handle
					INVOKE GetProcessHeap
 00000000  E8 00000000 E   *	    call   GetProcessHeap
					
					.IF eax == NULL
 00000005  0B C0	   *	    or	eax, eax
 00000007  75 04	   *	    jne    @C0001
 00000009  EB 26				jmp quit
					.ELSE 
 0000000B  EB 05	   *	    jmp    @C0003
 0000000D		   *@C0001:
 0000000D  A3 00000000 R			mov hHeap, eax
					.ENDIF
 00000012		   *@C0003:

					; // Allocate memory
					INVOKE HeapAlloc, hHeap, HEAP_ZERO_MEMORY, 1000
 00000012  68 000003E8	   *	    push   +0000003E8h
 00000017  6A 08	   *	    push   +000000008h
 00000019  FF 35 00000000 R *	    push   hHeap
 0000001F  E8 00000000 E   *	    call   HeapAlloc
					.IF eax == NULL
 00000024  0B C0	   *	    or	eax, eax
 00000026  75 04	   *	    jne    @C0004
 00000028  EB 07				jmp quit
					.ELSE
 0000002A  EB 05	   *	    jmp    @C0006
 0000002C		   *@C0004:
 0000002C  A3 00000004 R			mov pMemory, eax
					.ENDIF
 00000031		   *@C0006:

					; // Free memory


 00000031				quit:
					INVOKE ExitProcess, 0
 00000031  6A 00	   *	    push   +000000000h
 00000033  E8 00000000 E   *	    call   ExitProcess
 00000038			main ENDP

				END main
