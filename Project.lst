				; // ********************************************
				; // Constructor Methods
				; // ********************************************

				; // ----------------------------------
				; // init_neon_game_manager
				; // Initializes memory with the contents of a NeonGameManager
				; // 
				; // Register Parameters: 
				; //	ecx - THIS pointer
				; // ----------------------------------
 00000000			init_neon_game_manager PROC PUBLIC USES esi ebx edx
					local pThis
 00000000  55		   *	    push   ebp
 00000001  8B EC	   *	    mov    ebp, esp
 00000003  83 C4 FC	   *	    add    esp, 0FFFFFFFCh
 00000006  56		   *	    push   esi
 00000007  53		   *	    push   ebx
 00000008  52		   *	    push   edx
 00000009  89 4D FC			mov pThis, ecx

					; // Parent constructor
					INVOKE init_game_object, 2
 0000000C  6A 02	   *	    push   +000000002h
 0000000E  E8 00000000 E   *	    call   init_game_object
 00000013  C7 01 00000004		mov (GameObject PTR [ecx]).gameObjectType, NEON_GAME_MANAGER_GAME_OBJECT_ID
 00000019  C7 41 10			mov (GameObject PTR [ecx]).pVt, OFFSET NEON_GAME_MANAGER_GAMEOBJECT_VTABLE
	   00000000 R

					; // My constructor
 00000020  C7 41 1C			mov (NeonGameManager PTR [ecx]).timer, 0
	   00000000
 00000027  C7 41 20			mov (NeonGameManager PTR [ecx]).state, DEFAULT_STATE_ENUM
	   00000000
 0000002E  C7 41 24			mov (NeonGameManager PTR [ecx]).stateObjectCounter, defaultStateObjectMin
	   0000000F
						
 00000035  8B 45 FC			mov eax, pThis
						
					ret
 00000038  5A		   *	    pop    edx
 00000039  5B		   *	    pop    ebx
 0000003A  5E		   *	    pop    esi
 0000003B  C9		   *	    leave  
 0000003C  C3		   *	    ret    00000h
 0000003D			init_neon_game_manager ENDP

				; // ----------------------------------
				; // new_neon_game_manager
				; // Reserves heap space for the Object with parameters calls the initializer method
				; // ----------------------------------
 0000003D			new_neon_game_manager PROC PUBLIC USES ecx
 0000003D  51		   *	    push   ecx
					INVOKE HeapAlloc, hHeap, HEAP_GENERATE_EXCEPTIONS, SIZEOF NeonGameManager
 0000003E  6A 28	   *	    push   +000000028h
 00000040  6A 04	   *	    push   +000000004h
 00000042  FF 35 00000000 E *	    push   hHeap
 00000048  E8 00000000 E   *	    call   HeapAlloc
 0000004D  8B C8			mov ecx, eax ; // Move the memory address to ecx so it can function as a "this" pointer
					INVOKE init_neon_game_manager
 0000004F  E8 FFFFFFAC	   *	    call   init_neon_game_manager

					ret ; // Return with the address of the memory block in HeapAlloc
 00000054  59		   *	    pop    ecx
 00000055  C3		   *	    ret    00000h
 00000056			new_neon_game_manager ENDP

				; // ********************************************
				; // Instance methods
				; // ********************************************

				; // ----------------------------------
				; // transition_state
				; // Randomly decides what the next state will be
				; // 
				; // Register Parameters: 
				; //	ecx - THIS pointer
				; // ----------------------------------
 00000056			transition_state PROC USES eax ebx edx esi edi
 00000056  50		   *	    push   eax
 00000057  53		   *	    push   ebx
 00000058  52		   *	    push   edx
 00000059  56		   *	    push   esi
 0000005A  57		   *	    push   edi
 0000005B  B8 00000001			mov eax, 1
					INVOKE RandomRange
 00000060  E8 00000000 E   *	    call   RandomRange

					.IF eax == DEFAULT_STATE_ENUM
 00000065  0B C0	   *	    or	eax, eax
 00000067  75 23	   *	    jne    @C0001
 00000069  C7 41 20				mov (NeonGameManager PTR [ecx]).state, DEFAULT_STATE_ENUM
	   00000000
 00000070  C7 41 1C				mov (NeonGameManager PTR [ecx]).timer, 0
	   00000000
						
						; // Get a random number of objects in this scene
 00000077  B8 0000001E				mov eax, defaultStateObjectMax
 0000007C  83 E8 0F				sub eax, defaultStateObjectMin
						
						INVOKE RandomRange
 0000007F  E8 00000000 E   *	    call   RandomRange
 00000084  83 C0 0F				add eax, defaultStateObjectMin

 00000087  89 41 24				mov (NeonGameManager PTR [ecx]).stateObjectCounter, eax
					.ELSEIF eax == TUNNEL_STATE_ENUM
 0000008A  EB 05	   *	    jmp    @C0003
 0000008C		   *@C0001:
 0000008C  83 F8 01	   *	    cmp    eax, TUNNEL_STATE_ENUM
