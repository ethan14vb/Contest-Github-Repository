				; // ----------------------------------
				; // initializeRenderer
				; // Initializes the console for rendering by switching to UTF-8 format and 
				; // enabling virtual terminal processing for full RGB support.
				; // 
				; // ----------------------------------
 00000157			initializeRenderer PROC PUBLIC USES eax
