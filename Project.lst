				; // ----------------------------------
				; // init_neon_game_manager
				; // Initializes memory with the contents of a NeonGameManager
				; // 
				; // Register Parameters: 
				; //	ecx - THIS pointer
				; // ----------------------------------
 00000000			init_neon_game_manager PROC PUBLIC USES esi ebx edx
					local pThis
 00000000  55		   *	    push   ebp
 00000001  8B EC	   *	    mov    ebp, esp
 00000003  83 C4 FC	   *	    add    esp, 0FFFFFFFCh
 00000006  56		   *	    push   esi
 00000007  53		   *	    push   ebx
 00000008  52		   *	    push   edx
 00000009  89 4D FC			mov pThis, ecx

					; // Parent constructor
					INVOKE init_game_object, 2
 0000000C  6A 02	   *	    push   +000000002h
 0000000E  E8 00000000 E   *	    call   init_game_object
 00000013  C7 01 00000004		mov (GameObject PTR [ecx]).gameObjectType, NEON_GAME_MANAGER_GAME_OBJECT_ID
