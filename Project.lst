 00000000			.code
				; // ********************************************
				; // Constructor Methods
				; // ********************************************

				; // ----------------------------------
				; // init_scene
				; // Initializes memory with the contents of a Scene
				; // 
				; // Register Parameters: 
				; //	ecx - THIS pointer
				; // ----------------------------------
 00000000			init_scene PROC PUBLIC USES esi, maxGameObjects : DWORD
 00000000  55		   *	    push   ebp
 00000001  8B EC	   *	    mov    ebp, esp
 00000003  56		   *	    push   esi
 00000004  8B F1			mov esi, ecx ; // Save off my THIS pointer in esi

 00000006  8D 4E 10			lea ecx, (Scene PTR [esi]).gameObjects
					INVOKE init_unordered_vector, maxGameObjects
 00000009  FF 75 08	   *	    push   dword  ptr ss:[ebp]+000000008h
 0000000C  E8 00000000 E   *	    call   init_unordered_vector

 00000011  8D 4E 1C			lea ecx, (Scene PTR [esi]).startQueue
					INVOKE init_unordered_vector, maxGameObjects
 00000014  FF 75 08	   *	    push   dword  ptr ss:[ebp]+000000008h
 00000017  E8 00000000 E   *	    call   init_unordered_vector

 0000001C  8D 4E 28			lea ecx, (Scene PTR [esi]).freeQueue
					INVOKE init_unordered_vector, maxGameObjects
 0000001F  FF 75 08	   *	    push   dword  ptr ss:[ebp]+000000008h
 00000022  E8 00000000 E   *	    call   init_unordered_vector
					
 00000027  8D 4E 34			lea ecx, (Scene PTR [esi]).renderCommands
					INVOKE init_unordered_vector, maxGameObjects
 0000002A  FF 75 08	   *	    push   dword  ptr ss:[ebp]+000000008h
 0000002D  E8 00000000 E   *	    call   init_unordered_vector

 00000032  8B CE			mov ecx, esi ; // Restore my THIS pointer
						
					ret
 00000034  5E		   *	    pop    esi
 00000035  C9		   *	    leave  
 00000036  C2 0004	   *	    ret    00004h
 00000039			init_scene ENDP

				; // ----------------------------------
				; // new_scene
				; // Reserves heap space for the scene with parameters and calls the initializer method
				; // ----------------------------------
 00000039			new_scene PROC PUBLIC USES ecx, maxGameObjects : DWORD
 00000039  55		   *	    push   ebp
 0000003A  8B EC	   *	    mov    ebp, esp
 0000003C  51		   *	    push   ecx
					INVOKE HeapAlloc, hHeap, HEAP_GENERATE_EXCEPTIONS, SIZEOF Scene
 0000003D  6A 40	   *	    push   +000000040h
 0000003F  6A 04	   *	    push   +000000004h
 00000041  FF 35 00000000 E *	    push   hHeap
 00000047  E8 00000000 E   *	    call   HeapAlloc
 0000004C  8B C8			mov ecx, eax ; // Move the memory address to ecx so it can function as a "this" pointer
					INVOKE init_scene, maxGameObjects
 0000004E  FF 75 08	   *	    push   dword  ptr ss:[ebp]+000000008h
 00000051  E8 FFFFFFAA	   *	    call   init_scene
 00000056  8B C1			mov eax, ecx ; // Now return the THIS pointer

					ret ; // Return with the address of the memory block in HeapAlloc
 00000058  59		   *	    pop    ecx
 00000059  C9		   *	    leave  
 0000005A  C2 0004	   *	    ret    00004h
 0000005D			new_scene ENDP

				; // ----------------------------------
				; // free_scene
				; // Convenient method for freeing a Scene
				; //
				; // Register Parameters: 
				; //	ecx - THIS pointer
				; // ----------------------------------
 0000005D			free_scene PROC PUBLIC
					INVOKE HeapFree, hHeap, 0, ecx
 0000005D  51		   *	    push   ecx
 0000005E  6A 00	   *	    push   +000000000h
 00000060  FF 35 00000000 E *	    push   hHeap
 00000066  E8 00000000 E   *	    call   HeapFree
 0000006B  C3				ret
 0000006C			free_scene ENDP


				; // ********************************************
				; // Class methods
				; // ********************************************

				; // ----------------------------------
				; // add_game_object
				; // Adds a game object to the scene's start queue
				; //
				; // Register Parameters: 
				; //	ecx - THIS pointer
				; // ----------------------------------
 0000006C			instantiate_game_object PROC PUBLIC USES esi, pGameObject: DWORD
 0000006C  55		   *	    push   ebp
 0000006D  8B EC	   *	    mov    ebp, esp
 0000006F  56		   *	    push   esi
 00000070  8B F1			mov esi, ecx ; // Store the THIS pointer in ecx

 00000072  8D 49 1C			lea ecx, (Scene PTR[ecx]).startQueue
					INVOKE push_back, pGameObject
 00000075  FF 75 08	   *	    push   dword  ptr ss:[ebp]+000000008h
 00000078  E8 00000000 E   *	    call   push_back

 0000007D  8B CE			mov ecx, esi ; // Restore the THIS pointer
					ret
