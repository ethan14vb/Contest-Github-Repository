				; // ----------------------------------
				; // init_scene
				; // Initializes memory with the contents of a Scene
				; // 
				; // Register Parameters: 
				; //	ecx - THIS pointer
				; // ----------------------------------
 00000000			init_scene PROC PUBLIC USES esi, maxGameObjects : DWORD
 00000000  55		   *	    push   ebp
 00000001  8B EC	   *	    mov    ebp, esp
 00000003  56		   *	    push   esi
 00000004  8B F1			mov esi, ecx ; // Save off my THIS pointer in esi

 00000006  8D 0E			lea ecx, (Scene PTR [esi]).gameObjects
					INVOKE init_unordered_vector, maxGameObjects
 00000008  FF 75 08	   *	    push   dword  ptr ss:[ebp]+000000008h
 0000000B  E8 00000000 E   *	    call   init_unordered_vector

 00000010  8D 4E 0C			lea ecx, (Scene PTR [esi]).startQueue
					INVOKE init_unordered_vector, maxGameObjects
 00000013  FF 75 08	   *	    push   dword  ptr ss:[ebp]+000000008h
 00000016  E8 00000000 E   *	    call   init_unordered_vector

 0000001B  8D 4E 18			lea ecx, (Scene PTR [esi]).freeQueue
					INVOKE init_unordered_vector, maxGameObjects
 0000001E  FF 75 08	   *	    push   dword  ptr ss:[ebp]+000000008h
 00000021  E8 00000000 E   *	    call   init_unordered_vector
					
 00000026  8D 4E 24			lea ecx, (Scene PTR [esi]).renderCommands
					INVOKE init_unordered_vector, maxGameObjects
 00000029  FF 75 08	   *	    push   dword  ptr ss:[ebp]+000000008h
 0000002C  E8 00000000 E   *	    call   init_unordered_vector

 00000031  8B CE			mov ecx, esi ; // Restore my THIS pointer
						
					ret
 00000033  5E		   *	    pop    esi
 00000034  C9		   *	    leave  
 00000035  C2 0004	   *	    ret    00004h
 00000038			init_scene ENDP

				; // ----------------------------------
				; // new_scene
				; // Reserves heap space for the scene with parameters and calls the initializer method
				; // ----------------------------------
 00000038			new_scene PROC PUBLIC USES ecx, maxGameObjects : DWORD
 00000038  55		   *	    push   ebp
 00000039  8B EC	   *	    mov    ebp, esp
 0000003B  51		   *	    push   ecx
					INVOKE HeapAlloc, hHeap, HEAP_GENERATE_EXCEPTIONS, SIZEOF Scene
 0000003C  6A 30	   *	    push   +000000030h
 0000003E  6A 04	   *	    push   +000000004h
 00000040  FF 35 00000000 E *	    push   hHeap
 00000046  E8 00000000 E   *	    call   HeapAlloc
 0000004B  8B C8			mov ecx, eax ; // Move the memory address to ecx so it can function as a "this" pointer
					INVOKE init_scene, maxGameObjects
 0000004D  FF 75 08	   *	    push   dword  ptr ss:[ebp]+000000008h
 00000050  E8 FFFFFFAB	   *	    call   init_scene
 00000055  8B C1			mov eax, ecx ; // Now return the THIS pointer

					ret ; // Return with the address of the memory block in HeapAlloc
 00000057  59		   *	    pop    ecx
 00000058  C9		   *	    leave  
 00000059  C2 0004	   *	    ret    00004h
 0000005C			new_scene ENDP

				; // ----------------------------------
				; // free_scene
				; // Convenient method for freeing a Scene
				; //
				; // Register Parameters: 
				; //	ecx - THIS pointer
				; // ----------------------------------
 0000005C			free_scene PROC PUBLIC
					INVOKE HeapFree, hHeap, 0, ecx
 0000005C  51		   *	    push   ecx
 0000005D  6A 00	   *	    push   +000000000h
 0000005F  FF 35 00000000 E *	    push   hHeap
 00000065  E8 00000000 E   *	    call   HeapFree
 0000006A  C3				ret
 0000006B			free_scene ENDP


