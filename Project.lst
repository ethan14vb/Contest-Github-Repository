 000000D0			free_game_object PROC PUBLIC USES eax esi ebx
					; // Destruct the components
 000000D0  50		   *	    push   eax
 000000D1  56		   *	    push   esi
 000000D2  53		   *	    push   ebx
 000000D3  8B F1			mov esi, ecx ; // Move the this pointer to esi
 000000D5  8D 49 04			lea ecx, (GameObject PTR [ecx]).components

