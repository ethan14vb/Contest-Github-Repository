				; // ==================================
				; // input_manager.asm
				; // ----------------------------------
				; // The input manager is responsible for determining
				; // which keys are currently pressed and providing
				; // a convenient method for other files to determine
				; // the currently pressed keys. This should be
				; // updated on a by-frame basis by a scene.
				; // ==================================

				INCLUDE default_header.inc
			      C .386
			      C .model flat, stdcall
			      C option casemap : none
			      C .stack 4096
			      C OPTION PROC : PRIVATE
			      C 

				GetKeyboardState PROTO pBuffer : DWORD

 00000000			.data
				; // Holds the data for all 256 virtual keys and whether they are currently pressed
 00000000  00000100 [		curInputBuffer BYTE 256 DUP(0)
	    00
	   ]

				; // Holds the data for the previous input buffer for determining if a key was just pressed
 00000100  00000100 [		prevInputBuffer BYTE 256 DUP(0)
	    00
	   ]

 00000000			.code
				; // ----------------------------------
				; // updateInput
				; // This should be called every frame by Scene. Updates the 
				; // current and previous buffers.
				; // ----------------------------------
 00000000			updateInput PROC
					; // Copy the current buffer to the previous
 00000000  FC				cld
 00000001  BE 00000000 R	    mov esi, OFFSET curInputBuffer
 00000006  BF 00000100 R	    mov edi, OFFSET prevInputBuffer
 0000000B  B9 00000100		    mov ecx, 256
 00000010  F3/ A4		    rep movsb

					; // Get the current input state
					; // This is a Win32 API function that was added to the program before we learned about it
					; // during class. This function was used because it provided the greatest flexibility
					; // compared to the Irvine32 libraries for this engine.
					; // Documentation used: learn.microsoft.com/en-us/windows/win32/api/winuser/nf-winuser-getkeyboardstate
					INVOKE GetKeyboardState, OFFSET curInputBuffer
 00000012  68 00000000 R   *	    push   dword  ptr OFFSET FLAT: curInputBuffer
 00000017  E8 00000000 E   *	    call   GetKeyboardState

 0000001C  C3				ret
 0000001D			updateInput ENDP

				; // ----------------------------------
				; // isKeyPressed
				; // Returns 1 if a key is currently pressed and 0 if a key
				; // is not currently pressed this frame.
				; // ----------------------------------
 0000001D			isKeyPressed PROC, vkCode: DWORD
 0000001D  55		   *	    push   ebp
 0000001E  8B EC	   *	    mov    ebp, esp
 00000020  8A 85 00000008 R		mov al, [curInputBuffer + vkCode]
 00000026  A8 80			test al, 80h ; // Test the high bit
 00000028  74 07			jz keyNotPressed

					; // Key is pressed, return 1
 0000002A  B8 00000001			mov eax, 1
 0000002F  EB 05			jmp exitIsKeyPressed

 00000031			keyNotPressed:
 00000031  B8 00000000			mov eax, 0

 00000036			exitIsKeyPressed:
					ret
 00000036  C9		   *	    leave  
 00000037  C2 0004	   *	    ret    00004h
 0000003A			isKeyPressed ENDP

				END
