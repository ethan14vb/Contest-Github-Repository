 0000006C  8B EC	   *	    mov    ebp, esp
 0000006E  56		   *	    push   esi
 0000006F  8B F1			mov esi, ecx ; // Store the THIS pointer in ecx

 00000071  8D 49 0C			lea ecx, (Scene PTR[ecx]).startQueue
					INVOKE push_back, pGameObject
 00000074  FF 75 08	   *	    push   dword  ptr ss:[ebp]+000000008h
 00000077  E8 00000000 E   *	    call   push_back

 0000007C  8B CE			mov ecx, esi ; // Restore the THIS pointer
					ret
 0000007E  5E		   *	    pop    esi
 0000007F  C9		   *	    leave  
 00000080  C2 0004	   *	    ret    00004h
 00000083			instantiate_game_object ENDP

				; // ----------------------------------
				; // scene_process_start_queue
				; // Moves the GameObjects from the startQueue to the gameObjects vector 
				; // and then calls their start() methods.
				; //
				; // Register Parameters: 
				; //	ecx - THIS pointer
				; // ----------------------------------
 00000083			scene_process_start_queue PROC PRIVATE USES eax ebx edx esi edi
					local pThis
 00000083  55		   *	    push   ebp
 00000084  8B EC	   *	    mov    ebp, esp
 00000086  83 C4 FC	   *	    add    esp, 0FFFFFFFCh
 00000089  50		   *	    push   eax
 0000008A  53		   *	    push   ebx
 0000008B  52		   *	    push   edx
 0000008C  56		   *	    push   esi
 0000008D  57		   *	    push   edi
 0000008E  89 4D FC			mov pThis, ecx ; // Save the THIS pointer just in case

 00000091  8D 49 0C			lea ecx, (Scene PTR [ecx]).startQueue
 00000094  8B 59 04			mov ebx, (UnorderedVector PTR [ecx]).count
