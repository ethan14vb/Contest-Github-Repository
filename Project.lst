				; // ----------------------------------
				; // writeByteInDecimal
				; // Writes a single byte's decimal representation using ASCII characters into a buffer. 
				; // 
				; // Parameters: 
				; //	AL - byte to print
				; //    EDI - pointer to the buffer to write text to
				; //
				; // Registers changed:
				; //	EDI - will be adjusted after prints. Does not add null terminator.
				; // ----------------------------------
 00000000			writeByteInDecimal PROC USES ebx
					; // divide by 100
 00000000  53		   *	    push   ebx
 00000001  32 E4			xor ah, ah
 00000003  B3 64			mov bl, 100
 00000005  F6 F3			div bl

 00000007  3C 00			cmp al, 0
 00000009  74 05			je print_tens

					; // print result (100s place)
 0000000B  04 30			add al, '0' ; // Add 0x30 to display correct ASCII number representation
 0000000D  88 07			mov [edi], al
 0000000F  47				inc edi

 00000010			print_tens:
 00000010  8A C4			mov al, ah
 00000012  32 E4			xor ah, ah

 00000014  B3 0A			mov bl, 10
 00000016  F6 F3			div bl

 00000018  3C 00			cmp al, 0
 0000001A  74 05			je print_ones

					; // print result (10s place)
 0000001C  04 30			add al, '0'
 0000001E  88 07			mov [edi], al
 00000020  47				inc edi

 00000021			print_ones:
					; // print remainder (1s place)
 00000021  80 C4 30			add ah, '0'
 00000024  88 27			mov[edi], ah	
 00000026  47				inc edi
					ret
 00000027  5B		   *	    pop    ebx
 00000028  C3		   *	    ret    00000h
 00000029			writeByteInDecimal ENDP

				; // ----------------------------------
				; // displayBuffer
				; // Renders an RGBA buffer to the screen using ASCII characters.
				; // Intended to be used for frame by frame animation. 
				; // 
				; // Parameters: 
				; //	EAX - pointer to the new frame buffer to render. MUST BE SCREEN_WIDTH * SCREEN_HEIGHT!!!
				; //
				; // ----------------------------------
 00000029			displayBuffer PROC USES esi edi ecx ebx
 00000029  56		   *	    push   esi
 0000002A  57		   *	    push   edi
 0000002B  51		   *	    push   ecx
 0000002C  53		   *	    push   ebx
 0000002D  8B F0			mov esi, eax; // move source frame to esi
 0000002F  BF 00003E80 R		mov edi, OFFSET outputTextBuffer ; // move destination text buffer to edi

 00000034  33 DB			xor ebx, ebx ; // y_index = 0

 00000036			y_loop:
 00000036  83 FB 32			cmp ebx, SCREEN_HEIGHT
 00000039  7D 32			jge done

 0000003B  33 C9			xor ecx, ecx ; // x_index = 0
 0000003D			x_loop:
 0000003D  83 F9 50			cmp ecx, SCREEN_WIDTH
 00000040  7D 1E			jge row_end

					; // Get top pixel
					; // ((y_index * SCREENWIDTH) + x_index) * 2
 00000042  8B C3			mov eax, ebx
 00000044  6B C0 50			imul eax, SCREEN_WIDTH
 00000047  03 C1			add eax, ecx 
 00000049  C1 E0 02			shl eax, 2
 0000004C  8B 14 30			mov edx, [esi + eax] ; // edx is now the top pixel

					; // Get bottom pixel
					; // (((y_index + 1) * SCREENWIDTH) + x_index) * 2
 0000004F  8B C3			mov eax, ebx
 00000051  40				inc eax 
 00000052  6B C0 50			imul eax, SCREEN_WIDTH
 00000055  03 C1			add eax, ecx
 00000057  C1 E0 02			shl eax, 2
 0000005A  8B 04 30			mov eax, [esi + eax] ; // eax is now the bottom pixel

					; // Write character
					; // Write ESC[38;2;RRR;GGG;BBBm
					; // Write ESC[48;2;RRR;GGG;BBBm
					; // Write half block

 0000005D  41				inc ecx
 0000005E  EB DD			jmp x_loop

 00000060			row_end:
					; // Add newline
 00000060  C6 07 0D			mov byte PTR[edi], CR
 00000063  47				inc edi
 00000064  C6 07 0A			mov byte PTR[edi], LF
 00000067  47				inc edi

 00000068  83 C3 02			add ebx, 2 ; // y += 2

 0000006B  EB C9			jmp y_loop


 0000006D			done: 
