			      C 
			      C 
			      C ; // Enumerations
			      C RC_ENUM TYPEDEF DWORD
			      C 
 = 00000000		      C RC_RECT = 0 ; // RenderCommand Rectangle
 = 00000001		      C RC_SPRITE = 1 ; // RenderCommand Sprite NYI
			      C 
 0000000C		      C RenderCommand STRUCT
 00000000  00000000	      C 	rcType RC_ENUM ? ; // Render command type
			      C 
