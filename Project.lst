				; // ==================================
				; // input_manager.asm
				; // ----------------------------------
				; // The input manager is responsible for determining
				; // which keys are currently pressed and providing
				; // a convenient method for other files to determine
				; // the currently pressed keys. This should be
				; // updated on a by-frame basis by a scene.
				; // ==================================

				INCLUDE default_header.inc
			      C .386
			      C .model flat, stdcall
			      C option casemap : none
			      C .stack 4096
			      C OPTION PROC : PRIVATE
			      C 
				INCLUDE input_manager.inc
			      C ; // ==================================
			      C ; // input_manager.inc
			      C ; // ----------------------------------
			      C ; // The input manager is responsible for determining
			      C ; // which keys are currently pressed and providing
			      C ; // a convenient method for other files to determine
			      C ; // the currently pressed keys. This should be
			      C ; // updated on a by-frame basis by a scene.
			      C ; // ==================================
			      C 
			      C IFNDEF INPUT_MANAGER_INC
 = 00000001		      C INPUT_MANAGER_INC EQU 1
			      C 
			      C VK_CODE typedef BYTE 
			      C 
			      C ; // Win32 virtual key codes taken from learn.microsoft.com/en-us/windows/win32/inputdev/virtual-key-codes
 = 00000025		      C VK_LEFT		=	025h
 = 00000026		      C VK_UP		=	026h
 = 00000027		      C VK_RIGHT	=	027h
 = 00000028		      C VK_DOWN		=	028h
			      C 
			      C updateInput PROTO
			      C isKeyPressed PROTO vkCode: VK_CODE
			      C isKeyJustPressed PROTO vkCode: VK_CODE
			      C 
			      C ENDIF
			      C 

				; // This is a Win32 API function that was added to the program out of need, 
				; // although we did not learn about it in class. The reason this function is present
				; // is because it allows for a "real-time" input system where the hardware is polled
				; // at the instant the frame is updated to determine what keys are currently being
				; // pressed. Because the function is asynchronous, we can call it at any time and it
				; // will reliably spit out the exact keys being pressed.
				; // Documentation used: learn.microsoft.com/en-us/windows/win32/api/winuser/nf-winuser-getasynckeystate
				GetAsyncKeyState PROTO vk_code : DWORD
					
 00000000			.data
				; // Holds the data for all 256 virtual keys and whether they are currently pressed
 00000000  00000100 [		curInputBuffer BYTE 256 DUP(0)
	    00
	   ]

				; // Holds the data for the previous input buffer for determining if a key was just pressed
 00000100  00000100 [		prevInputBuffer BYTE 256 DUP(0)
	    00
	   ]

 00000000			.code
				; // ----------------------------------
				; // updateInput
				; // This should be called every frame by Scene. Updates the 
				; // current and previous buffers.
				; // ----------------------------------
 00000000			updateInput PROC PUBLIC USES ebx ecx edx esi edi
					; // Copy the current buffer to the previous
 00000000  53		   *	    push   ebx
 00000001  51		   *	    push   ecx
 00000002  52		   *	    push   edx
 00000003  56		   *	    push   esi
 00000004  57		   *	    push   edi
 00000005  FC				cld
 00000006  BE 00000000 R	    mov esi, OFFSET curInputBuffer
 0000000B  BF 00000100 R	    mov edi, OFFSET prevInputBuffer
 00000010  B9 00000100		    mov ecx, 256
 00000015  F3/ A4		    rep movsb

					; // Get the current input state for all 256 key codes
 00000017  BB 00000000			mov ebx, 0
					.WHILE ebx <= 0FFh
 0000001C  EB 1C	   *	    jmp    @C0001
 0000001E		   *@C0002:
						INVOKE GetAsyncKeyState, ebx
 0000001E  53		   *	    push   ebx
 0000001F  E8 00000000 E   *	    call   GetAsyncKeyState
 00000024  F6 C4 80				test ah, 80h
 00000027  74 09				jz keyUp

 00000029				keyDown:
 00000029  C6 83 00000000 R			mov curInputBuffer[ebx], 80h ; // Set the most significant bit
	   80
 00000030  EB 07				jmp endLoop
 00000032				keyUp:
 00000032  C6 83 00000000 R			mov curInputBuffer[ebx], 0 ; // Clear the most significant bit
	   00
 00000039				endLoop:
 00000039  43					inc ebx
					.ENDW
 0000003A		   *@C0001:
 0000003A  81 FB 000000FF  *	    cmp    ebx, 0FFh
 00000040  76 DC	   *	    jbe    @C0002

					ret
 00000042  5F		   *	    pop    edi
 00000043  5E		   *	    pop    esi
 00000044  5A		   *	    pop    edx
 00000045  59		   *	    pop    ecx
 00000046  5B		   *	    pop    ebx
 00000047  C3		   *	    ret    00000h
 00000048			updateInput ENDP

				; // ----------------------------------
				; // isKeyPressed
				; // Returns 1 if a key is currently pressed and 0 if a key
				; // is not currently pressed this frame.
				; // ----------------------------------
 00000048			isKeyPressed PROC PUBLIC USES ebx, vkCode: VK_CODE
 00000048  55		   *	    push   ebp
 00000049  8B EC	   *	    mov    ebp, esp
 0000004B  53		   *	    push   ebx
 0000004C  0F B6 5D 08			movzx ebx, vkCode
 00000050  8A 83 00000000 R		mov al, curInputBuffer[ebx]
 00000056  A8 80			test al, 80h ; // Test the high bit
 00000058  74 07			jz keyNotPressed

					; // Key is pressed, return 1
 0000005A  B8 00000001			mov eax, 1
 0000005F  EB 05			jmp exitIsKeyPressed

 00000061			keyNotPressed:
 00000061  B8 00000000			mov eax, 0

 00000066			exitIsKeyPressed:
					ret
 00000066  5B		   *	    pop    ebx
 00000067  C9		   *	    leave  
 00000068  C2 0004	   *	    ret    00004h
 0000006B			isKeyPressed ENDP

				; // ----------------------------------
				; // isKeyJustPressed
				; // Returns 1 if a key is just pressed this frame and 0 if the key
				; // was not just pressed this frame.
				; // ----------------------------------
 0000006B			isKeyJustPressed PROC PUBLIC USES ebx, vkCode: VK_CODE
 0000006B  55		   *	    push   ebp
 0000006C  8B EC	   *	    mov    ebp, esp
 0000006E  53		   *	    push   ebx
 0000006F  8A 85 00000008 R		mov al, curInputBuffer[vkCode]
 00000075  8A 9D 00000108 R		mov bl, prevInputBuffer[vkCode]

 0000007B  A8 80			test al, 80h ; // Test the high bit
 0000007D  74 0C			jz keyNotJustPressed
					
					; // Test if the key was also pressed last frame
 0000007F  F6 C3 80			test bl, 80h
 00000082  75 07			jnz keyNotJustPressed

					; // Key was just pressed, return 1
 00000084  B8 00000001			mov eax, 1
 00000089  EB 05			jmp exitIsKeyJustPressed
						
 0000008B			keyNotJustPressed:
 0000008B  B8 00000000			mov eax, 0
 00000090			exitIsKeyJustPressed:
					ret
 00000090  5B		   *	    pop    ebx
 00000091  C9		   *	    leave  
 00000092  C2 0004	   *	    ret    00004h
 00000095			isKeyJustPressed ENDP

