	   00000008
						
 00000035  8B 45 FC			mov eax, pThis
						
					ret
 00000038  5A		   *	    pop    edx
 00000039  5B		   *	    pop    ebx
 0000003A  5E		   *	    pop    esi
 0000003B  C9		   *	    leave  
 0000003C  C3		   *	    ret    00000h
