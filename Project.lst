 00000000			.code
				; // ----------------------------------
				; // writeByteInDecimal
				; // Writes a single byte's decimal representation using ASCII characters into a buffer. 
				; // 
				; // Parameters: 
				; //	AL - byte to print
				; //    EDI - pointer to the buffer to write text to
				; //
				; // Registers changed:
				; //	EDI - will be adjusted after prints. Does not add null terminator.
				; // ----------------------------------
 00000000			writeByteInDecimal PROC USES ebx
					; // divide by 100
 00000000  53		   *	    push   ebx
 00000001  32 E4			xor ah, ah
 00000003  B3 64			mov bl, 100
 00000005  F6 F3			div bl

 00000007  3C 00			cmp al, 0
 00000009  74 05			je print_tens

					; // print result (100s place)
 0000000B  04 30			add al, '0' ; // Add 0x30 to display correct ASCII number representation
 0000000D  88 07			mov [edi], al
 0000000F  47				inc edi

 00000010			print_tens:
 00000010  8A C4			mov al, ah
 00000012  32 E4			xor ah, ah

 00000014  B3 0A			mov bl, 10
 00000016  F6 F3			div bl

 00000018  3C 00			cmp al, 0
 0000001A  74 05			je print_ones

					; // print result (10s place)
 0000001C  04 30			add al, '0'
 0000001E  88 07			mov [edi], al
 00000020  47				inc edi

 00000021			print_ones:
					; // print remainder (1s place)
 00000021  80 C4 30			add ah, '0'
 00000024  88 27			mov[edi], ah	
 00000026  47				inc edi
					ret
 00000027  5B		   *	    pop    ebx
 00000028  C3		   *	    ret    00000h
 00000029			writeByteInDecimal ENDP

				; // ----------------------------------
				; // displayBuffer
				; // Renders an RGBA buffer to the screen using ASCII characters.
				; // Intended to be used for frame by frame animation. 
				; // 
				; // Parameters: 
				; //	pBuffer DWORD - pointer to the new frame buffer to render. MUST BE SCREEN_WIDTH * SCREEN_HEIGHT!!!
				; //
				; // ----------------------------------
 00000029			displayBuffer PROC PUBLIC USES esi edi ecx ebx, pBuffer:DWORD
 00000029  55		   *	    push   ebp
 0000002A  8B EC	   *	    mov    ebp, esp
 0000002C  56		   *	    push   esi
 0000002D  57		   *	    push   edi
 0000002E  51		   *	    push   ecx
 0000002F  53		   *	    push   ebx
 00000030  BF 00003E98 R		mov edi, OFFSET outputTextBuffer ; // move destination text buffer to edi

					INVOKE SetConsoleCursorPosition, hConsoleOutput, 0
 00000035  6A 00	   *	    push   +000000000h
 00000037  FF 35 00000008 R *	    push   hConsoleOutput
 0000003D  E8 00000000 E   *	    call   SetConsoleCursorPosition

 00000042  33 DB			xor ebx, ebx ; // y_index = 0

 00000044			y_loop:
 00000044  83 FB 32			cmp ebx, SCREEN_HEIGHT
 00000047  0F 8D 000000D2		jge done

 0000004D  33 C9			xor ecx, ecx ; // x_index = 0
 0000004F			x_loop:
 0000004F  83 F9 50			cmp ecx, SCREEN_WIDTH
 00000052  0F 8D 000000B7		jge row_end

					; // Get top pixel
					; // ((y_index * SCREENWIDTH) + x_index) * 2
 00000058  8B C3			mov eax, ebx
 0000005A  6B C0 50			imul eax, SCREEN_WIDTH
 0000005D  03 C1			add eax, ecx 
 0000005F  C1 E0 02			shl eax, 2
 00000062  8B 55 08			mov edx, pBuffer
 00000065  03 D0			add edx, eax ; // edx is now the top pixel

 00000067  52				push edx

					; // Get bottom pixel
					; // (((y_index + 1) * SCREENWIDTH) + x_index) * 2
 00000068  8B C3			mov eax, ebx
 0000006A  40				inc eax 
 0000006B  6B C0 50			imul eax, SCREEN_WIDTH
 0000006E  03 C1			add eax, ecx
 00000070  C1 E0 02			shl eax, 2
 00000073  8B 55 08			mov edx, pBuffer
 00000076  03 D0			add edx, eax 

 00000078  8B C2			mov eax, edx ; // eax is now the bottom pixel

 0000007A  5A				pop edx ; // restore the top pixel

					; // Write foreground ANSI prefix (ESC[38;2;RRR;GGG;BBB;m)
 0000007B  C6 07 1B			mov BYTE PTR[edi], ESCP
 0000007E  47				inc edi
 0000007F  C6 07 5B			mov BYTE PTR[edi], '['
 00000082  47				inc edi
 00000083  C6 07 33			mov BYTE PTR[edi], '3'
 00000086  47				inc edi
 00000087  C6 07 38			mov BYTE PTR[edi], '8'
 0000008A  47				inc edi
 0000008B  C6 07 3B			mov BYTE PTR[edi], ';'
 0000008E  47				inc edi
 0000008F  C6 07 32			mov BYTE PTR[edi], '2'
 00000092  47				inc edi
 00000093  C6 07 3B			mov BYTE PTR[edi], ';'
 00000096  47				inc edi

 00000097  52				push edx ; // push edx so we can use it
 00000098  8B D0			mov edx, eax

 0000009A  8A 02			mov al, [edx]
 0000009C  E8 FFFFFF5F			call writeByteInDecimal ; // Bottom RRR
 000000A1  C6 07 3B			mov BYTE PTR[edi], ';'
 000000A4  47				inc edi
 000000A5  8A 42 01			mov al, [edx + 1]
 000000A8  E8 FFFFFF53			call writeByteInDecimal ; // Bottom GGG
 000000AD  C6 07 3B			mov BYTE PTR[edi], ';'
 000000B0  47				inc edi
 000000B1  8A 42 02			mov al, [edx + 2]
 000000B4  E8 FFFFFF47			call writeByteInDecimal ; // Bottom BBB
 000000B9  C6 07 6D			mov BYTE PTR[edi], 'm'
 000000BC  47				inc edi

 000000BD  5A				pop edx ; // restore edx

					; // Write background ANSI prefix (ESC[48;2;RRR;GGG;BBB;m)
 000000BE  C6 07 1B			mov BYTE PTR[edi], ESCP
 000000C1  47				inc edi
 000000C2  C6 07 5B			mov BYTE PTR[edi], '['
 000000C5  47				inc edi
 000000C6  C6 07 34			mov BYTE PTR[edi], '4'
 000000C9  47				inc edi
 000000CA  C6 07 38			mov BYTE PTR[edi], '8'
 000000CD  47				inc edi
 000000CE  C6 07 3B			mov BYTE PTR[edi], ';'
 000000D1  47				inc edi
 000000D2  C6 07 32			mov BYTE PTR[edi], '2'
 000000D5  47				inc edi
 000000D6  C6 07 3B			mov BYTE PTR[edi], ';'
 000000D9  47				inc edi
 000000DA  8A 02			mov al, [edx]
 000000DC  E8 FFFFFF1F			call writeByteInDecimal; // Top RRR
 000000E1  C6 07 3B			mov BYTE PTR[edi], ';'
 000000E4  47				inc edi
 000000E5  8A 42 01			mov al, [edx + 1]
 000000E8  E8 FFFFFF13			call writeByteInDecimal; // Top GGG
 000000ED  C6 07 3B			mov BYTE PTR[edi], ';'
 000000F0  47				inc edi
 000000F1  8A 42 02			mov al, [edx + 2]
 000000F4  E8 FFFFFF07			call writeByteInDecimal; // Top BBB
 000000F9  C6 07 6D			mov BYTE PTR[edi], 'm'
