					INVOKE HeapAlloc, hHeap, HEAP_GENERATE_EXCEPTIONS, SIZEOF Component
 00000011  6A 08	   *	    push   +000000008h
 00000013  6A 04	   *	    push   +000000004h
 00000015  FF 35 00000000 E *	    push   hHeap
 0000001B  E8 00000000 E   *	    call   HeapAlloc
