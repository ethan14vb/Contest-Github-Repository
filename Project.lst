				; // ----------------------------------
				; // writeByteInDecimal
				; // Writes a single byte's decimal representation using ASCII characters into a buffer. 
				; // 
				; // Parameters: 
				; //	AL - byte to print
				; //    EDI - pointer to the buffer to write text to
				; //
				; // Registers changed:
				; //	EDI - will be adjusted after prints. Does not add null terminator.
				; // ----------------------------------
 00000000			writeByteInDecimal PROC USES ebx
					; // divide by 100
 00000000  53		   *	    push   ebx
 00000001  32 E4			xor ah, ah
 00000003  B3 64			mov bl, 100
 00000005  F6 F3			div bl

 00000007  3C 00			cmp al, 0
 00000009  74 05			je print_tens

					; // print result (100s place)
 0000000B  04 30			add al, '0' ; // Add 0x30 to display correct ASCII number representation
 0000000D  88 07			mov [edi], al
 0000000F  47				inc edi

 00000010			print_tens:
 00000010  8A C4			mov al, ah
 00000012  32 E4			xor ah, ah

 00000014  B3 0A			mov bl, 10
 00000016  F6 F3			div bl

 00000018  3C 00			cmp al, 0
 0000001A  74 05			je print_ones

					; // print result (10s place)
 0000001C  04 30			add al, '0'
 0000001E  88 07			mov [edi], al
 00000020  47				inc edi

 00000021			print_ones:
					; // print remainder (1s place)
 00000021  80 C4 30			add ah, '0'
 00000024  88 27			mov[edi], ah	
 00000026  47				inc edi
					ret
 00000027  5B		   *	    pop    ebx
 00000028  C3		   *	    ret    00000h
 00000029			writeByteInDecimal ENDP

				; // ----------------------------------
				; // displayBuffer
				; // Renders an RGBA buffer to the screen using ASCII characters.
				; // Intended to be used for frame by frame animation. 
				; // 
				; // Parameters: 
				; //	pBuffer DWORD - pointer to the new frame buffer to render. MUST BE SCREEN_WIDTH * SCREEN_HEIGHT!!!
				; //
				; // ----------------------------------
 00000029			displayBuffer PROC PUBLIC USES esi edi ecx ebx, pBuffer:DWORD
 00000029  55		   *	    push   ebp
 0000002A  8B EC	   *	    mov    ebp, esp
 0000002C  56		   *	    push   esi
 0000002D  57		   *	    push   edi
 0000002E  51		   *	    push   ecx
 0000002F  53		   *	    push   ebx
 00000030  BF 00003E8C R		mov edi, OFFSET outputTextBuffer ; // move destination text buffer to edi

 00000035  33 DB			xor ebx, ebx ; // y_index = 0

 00000037			y_loop:
 00000037  83 FB 32			cmp ebx, SCREEN_HEIGHT
 0000003A  0F 8D 000000D2		jge done

 00000040  33 C9			xor ecx, ecx ; // x_index = 0
 00000042			x_loop:
 00000042  83 F9 50			cmp ecx, SCREEN_WIDTH
 00000045  0F 8D 000000B7		jge row_end

					; // Get top pixel
					; // ((y_index * SCREENWIDTH) + x_index) * 2
 0000004B  8B C3			mov eax, ebx
 0000004D  6B C0 50			imul eax, SCREEN_WIDTH
 00000050  03 C1			add eax, ecx 
 00000052  C1 E0 02			shl eax, 2
 00000055  8B 55 08			mov edx, pBuffer
 00000058  03 D0			add edx, eax ; // edx is now the top pixel

 0000005A  52				push edx

					; // Get bottom pixel
					; // (((y_index + 1) * SCREENWIDTH) + x_index) * 2
 0000005B  8B C3			mov eax, ebx
 0000005D  40				inc eax 
 0000005E  6B C0 50			imul eax, SCREEN_WIDTH
 00000061  03 C1			add eax, ecx
 00000063  C1 E0 02			shl eax, 2
 00000066  8B 55 08			mov edx, pBuffer
 00000069  03 D0			add edx, eax 

 0000006B  8B C2			mov eax, edx ; // eax is now the bottom pixel

 0000006D  5A				pop edx ; // restore the top pixel

					; // Write foreground ANSI prefix (ESC[38;2;RRR;GGG;BBB;m)
 0000006E  C6 07 1B			mov BYTE PTR[edi], ESCP
 00000071  47				inc edi
 00000072  C6 07 5B			mov BYTE PTR[edi], '['
 00000075  47				inc edi
 00000076  C6 07 33			mov BYTE PTR[edi], '3'
 00000079  47				inc edi
 0000007A  C6 07 38			mov BYTE PTR[edi], '8'
 0000007D  47				inc edi
 0000007E  C6 07 3B			mov BYTE PTR[edi], ';'
 00000081  47				inc edi
 00000082  C6 07 32			mov BYTE PTR[edi], '2'
 00000085  47				inc edi
 00000086  C6 07 3B			mov BYTE PTR[edi], ';'
 00000089  47				inc edi

 0000008A  52				push edx ; // push edx so we can use it
 0000008B  8B D0			mov edx, eax

 0000008D  8A 02			mov al, [edx]
 0000008F  E8 FFFFFF6C			call writeByteInDecimal ; // Bottom RRR
 00000094  C6 07 3B			mov BYTE PTR[edi], ';'
 00000097  47				inc edi
 00000098  8A 42 01			mov al, [edx + 1]
 0000009B  E8 FFFFFF60			call writeByteInDecimal ; // Bottom GGG
 000000A0  C6 07 3B			mov BYTE PTR[edi], ';'
 000000A3  47				inc edi
 000000A4  8A 42 02			mov al, [edx + 2]
 000000A7  E8 FFFFFF54			call writeByteInDecimal ; // Bottom BBB
 000000AC  C6 07 6D			mov BYTE PTR[edi], 'm'
 000000AF  47				inc edi

 000000B0  5A				pop edx ; // restore edx

					; // Write background ANSI prefix (ESC[48;2;RRR;GGG;BBB;m)
 000000B1  C6 07 1B			mov BYTE PTR[edi], ESCP
 000000B4  47				inc edi
 000000B5  C6 07 5B			mov BYTE PTR[edi], '['
 000000B8  47				inc edi
 000000B9  C6 07 34			mov BYTE PTR[edi], '4'
 000000BC  47				inc edi
 000000BD  C6 07 38			mov BYTE PTR[edi], '8'
 000000C0  47				inc edi
 000000C1  C6 07 3B			mov BYTE PTR[edi], ';'
 000000C4  47				inc edi
 000000C5  C6 07 32			mov BYTE PTR[edi], '2'
 000000C8  47				inc edi
 000000C9  C6 07 3B			mov BYTE PTR[edi], ';'
 000000CC  47				inc edi
 000000CD  8A 02			mov al, [edx]
 000000CF  E8 FFFFFF2C			call writeByteInDecimal; // Top RRR
 000000D4  C6 07 3B			mov BYTE PTR[edi], ';'
 000000D7  47				inc edi
 000000D8  8A 42 01			mov al, [edx + 1]
 000000DB  E8 FFFFFF20			call writeByteInDecimal; // Top GGG
 000000E0  C6 07 3B			mov BYTE PTR[edi], ';'
 000000E3  47				inc edi
 000000E4  8A 42 02			mov al, [edx + 2]
