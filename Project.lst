 000000DA  8B 59 04			mov ebx, (UnorderedVector PTR [ecx]).count

 000000DD  B9 00000000			mov ecx, 0 ; // Loop counter (int i = 0)
					.WHILE ecx < ebx
 000000E2  EB 0F	   *	    jmp    @C0001
 000000E4		   *@C0002:
 000000E4  8B 14 88				mov edx, [eax + ecx * 4] ; // edx = pComponents[i]

						; // pComponents[i]->free()
 000000E7  51					push ecx
 000000E8  50					push eax
 000000E9  8B CA				mov ecx, edx
						INVOKE free_component_virtual
 000000EB  E8 00000000 E   *	    call   free_component_virtual
 000000F0  58					pop eax
 000000F1  59					pop ecx

 000000F2  41					inc ecx ; // i++
					.ENDW
 000000F3		   *@C0001:
 000000F3  3B CB	   *	    cmp    ecx, ebx
 000000F5  72 ED	   *	    jb	@C0002
					
 000000F7  8B CE			mov ecx, esi
 000000F9  8D 49 04			lea ecx, (GameObject PTR [ecx]).components
					INVOKE free_unordered_vector
 000000FC  E8 00000000 E   *	    call   free_unordered_vector

 00000101  8B CE			mov ecx, esi ; // Restore the THIS pointer to ecx

					INVOKE HeapFree, hHeap, 0, ecx ; // Free myself
 00000103  51		   *	    push   ecx
 00000104  6A 00	   *	    push   +000000000h
 00000106  FF 35 00000000 E *	    push   hHeap
