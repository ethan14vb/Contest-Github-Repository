					INVOKE init_component
 00000022  E8 FFFFFFD9	   *	    call   init_component

					ret ; // Return with the address of the memory block in HeapAlloc
 00000027  59		   *	    pop    ecx
 00000028  C3		   *	    ret    00000h
 00000029			new_component ENDP

				; // ecx stores the "this" pointer
 00000029			free_component PROC PUBLIC
					INVOKE HeapFree, hHeap, 0, ecx
 00000029  51		   *	    push   ecx
 0000002A  6A 00	   *	    push   +000000000h
 0000002C  FF 35 00000000 E *	    push   hHeap
 00000032  E8 00000000 E   *	    call   HeapFree
 00000037  C3				ret
