			      C IFNDEF GAME_OBJECT_INC
 = 00000001		      C GAME_OBJECT_INC EQU 1
			      C 
 0000000C		      C GameObject_vtable STRUCT
 00000000  00000000	      C 	pStart DWORD ? ; For initialization of the GameObject
 00000004  00000000	      C 	pUpdate DWORD ? ; For game logic that will run every frame update
 00000008  00000000	      C 	pExit DWORD ? ; Called when the GameObject is removed
			      C GameObject_vtable ENDS
			      C 
 0000000C		      C GameObject STRUCT
 00000000  00000000	      C 	numComponents DWORD ?
 00000004  00000000	      C 	pComponents DWORD ? ; Pointer to a table of components
 00000008  00000000	      C 	pVt DWORD ? ; Pointer to a virtual function table
			      C GameObject ENDS
			      C 
			      C ENDIF
