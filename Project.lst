				; // ----------------------------------
				; // transition_to_state
				; // Transitions to the next state
				; // 
				; // Register Parameters: 
				; //	ecx - THIS pointer
				; // ----------------------------------
 00000056			transition_to_state PROC USES eax ebx edx esi edi, state : GAME_MANAGER_STATE_ENUM
 00000056  55		   *	    push   ebp
 00000057  8B EC	   *	    mov    ebp, esp
 00000059  50		   *	    push   eax
 0000005A  53		   *	    push   ebx
 0000005B  52		   *	    push   edx
 0000005C  56		   *	    push   esi
 0000005D  57		   *	    push   edi
 0000005E  8B 45 08			mov eax, state

					.IF eax == DEFAULT_STATE_ENUM
