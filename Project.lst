				; // ==================================
				; // scene.asm
				; // ----------------------------------
				; // Scenes are classes that hold a single section of a game. A scene contains a
				; // pointer to a list of GameObjects that is updated by the scene_update function.
				; // The scene also updates simulations and any game logic that isn't handled directly
				; // by GameObjects or their components. At the end of every update, the scene will
				; // call the renderer module to render its contents.
				; // ==================================

				INCLUDE default_header.inc
			      C .386
			      C .model flat, stdcall
			      C option casemap : none
			      C .stack 4096
			      C OPTION PROC : PRIVATE
			      C 
				INCLUDE heap_functions.inc
			      C ; // ==================================
			      C ; // heap_functions.inc
			      C ; // ----------------------------------
			      C ; // Functions used for dynamic memory management. This file was
			      C ; // added before we learned about heap memory management in class
			      C ; // so we could have easy memory management. My resource for this 
			      C ; // was the windows API reference and the class ch11 slides.
			      C ; // ==================================
			      C 
			      C IFNDEF HEAP_FUNCTIONS_INC
 = 00000001		      C HEAP_FUNCTIONS_INC EQU 1
			      C 
			      C ; // Constants
 = 00000008		      C HEAP_ZERO_MEMORY          equ 00000008h
 = 00000004		      C HEAP_GENERATE_EXCEPTIONS  equ 00000004h
 = 00000001		      C HEAP_NO_SERIALIZE         equ 00000001h
			      C 
 = 00000000		      C NULL   EQU 0
			      C 
			      C ; // Types
			      C HANDLE TYPEDEF DWORD
			      C 
			      C ; // Protos
			      C GetProcessHeap	PROTO
			      C HeapAlloc		PROTO,	hHeap:DWORD, dwFlags:DWORD, dwBytes:DWORD
			      C HeapFree		PROTO,	hHeap:DWORD, dwFlags:DWORD, lpMem:DWORD
			      C HeapReAlloc		PROTO,	hHeap:DWORD, dwFlags:DWORD, lpMem:DWORD,	dwBytes:DWORD
			      C 
			      C initialize_heap PROTO ; // This function is from heap_functions.asm. It gets the handle to the process heap and stores in hHeap
			      C 
			      C ; // Data
			      C EXTERNDEF hHeap:HANDLE ; // the heap handle is defined in heap_functions.asm
			      C 
			      C ENDIF
			      C 
				INCLUDE scene.inc
			      C ; // ==================================
			      C ; // Scene
			      C ; // ----------------------------------
			      C ; // Scenes are classes that hold a single section of a game. A scene contains a
			      C ; // pointer to a list of GameObjects that is updated by the scene_update function.
			      C ; // The scene also updates simulations and any game logic that isn't handled directly
			      C ; // by GameObjects or their components. At the end of every update, the scene will
			      C ; // call the renderer module to render its contents.
			      C ; // ==================================
			      C 
			      C IFNDEF SCENE_INC
 = 00000001		      C SCENE_INC EQU 1
			      C 
			      C INCLUDE unordered_vector.inc
			      C ; // ==================================
			      C ; // unordered_vector.inc
			      C ; // ----------------------------------
			      C ; // unordered_vector are dynamic arrays of DWORDs
			      C ; // whose contents are not guaranteed to be in the same
			      C ; // order after a removal. They are typically used for 
			      C ; // pools of GameObject pointers whose order doesn't matter.
			      C ; // ==================================
			      C 
			      C IFNDEF UNORDERED_VECTOR_INC
 = 00000001		      C UNORDERED_VECTOR_INC EQU 1
			      C 
 0000000C		      C UnorderedVector STRUCT
 00000000  00000000	      C 	pData		DWORD ?
 00000004  00000000	      C 	count		DWORD ?
 00000008  00000000	      C 	capacity	DWORD ?
			      C UnorderedVector ENDS
			      C 
			      C ; // Constructors
			      C init_unordered_vector PROTO capacity : DWORD
			      C new_unordered_vector PROTO capacity: DWORD
			      C free_unordered_vector PROTO
			      C 
			      C ; // Instance methods
			      C push_back PROTO element: DWORD
			      C remove_element PROTO element: DWORD
			      C 
			      C ENDIF
			      C 
			      C INCLUDE camera.inc 
			      C ; // ==================================
			      C ; // Camera
			      C ; // ----------------------------------
			      C ; // A camera defines where spatially a scene should
			      C ; // render its GameObjects.
			      C ; // ==================================
			      C 
			      C IFNDEF CAMERA_INC
 = 00000001		      C CAMERA_INC EQU 1
			      C 
 00000010		      C Camera STRUCT
			      C 	; // Perhaps, some time in the future, this data could be 
			      C 	; // replaced by a TransformComponent.
 00000000  00000000	      C 	x DWORD ?
 00000004  00000000	      C 	y DWORD ?
 00000008  00000000	      C 	h DWORD ? ; // Viewport Height
 0000000C  00000000	      C 	w DWORD ? ; // Viewport Width
			      C Camera ENDS
			      C 
			      C ENDIF
			      C 
			      C 
 00000040		      C Scene STRUCT
 00000000  00000000	      C 	camera Camera<>
	   00000000
	   00000000
	   00000000
			      C 
			      C 	; // The list of GameObjects in this Scene instance.
 00000010  00000000	      C 	gameObjects UnorderedVector<>
	   00000000
	   00000000
			      C 	
			      C 	; // The start queue is a list of GameObjects created by the add_gameobject method
 0000001C  00000000	      C 	startQueue UnorderedVector<>
	   00000000
	   00000000
			      C 
			      C 	; // The free queue is a list of GameObjects to free at the end of the frame
 00000028  00000000	      C 	freeQueue UnorderedVector<>
	   00000000
	   00000000
			      C 
			      C 	; // The list of renderCommands that is built at the end of each frame
 00000034  00000000	      C 	renderCommands UnorderedVector<>
	   00000000
	   00000000
			      C Scene ENDS
			      C 
			      C ; // Constructors
			      C init_scene PROTO maxGameObjects		: DWORD
			      C new_scene PROTO maxGameObjects		: DWORD
			      C free_scene PROTO
			      C 
			      C ; // Instance methods
			      C instantiate_game_object PROTO pGameObject: DWORD
			      C scene_update PROTO deltaTime: REAL4
			      C 
			      C ENDIF
			      C 
				INCLUDE game_object.inc
			      C ; // ==================================
			      C ; // GameObject
			      C ; // ----------------------------------
			      C ; //	GameObjects are the core elements of a scene
			      C ; // that contain gameplay logic and anything the player
			      C ; // will see.
			      C ; //	This STRUCT is intended to be 'subclassed' by 
			      C ; // overriding the virtual function table.
			      C ; //	GameObjects contain a list of components that
			      C ; // define utility behavior such as sprites to render
			      C ; // or animation states. These componenets are updated
			      C ; // by the scene_update to keep their auxillary functionality
			      C ; // separate from main game logic.
			      C ; // ==================================
			      C 
			      C IFNDEF GAME_OBJECT_INC
 = 00000001		      C GAME_OBJECT_INC EQU 1
			      C 
			      C INCLUDE game_object_ids.inc
			      C ; // ==================================
			      C ; // game_object_ids.inc
			      C ; // ----------------------------------
			      C ; // A set of "enum" style macros that identify GameObject types 
			      C ; // for the data definition and parsing of a scene's data.
			      C ; //
			      C ; // This is necessary because GameObjects are designed to be
			      C ; // subclassed into new unique types of GameObjects defined
			      C ; // by the user of this engine.
			      C ; // ==================================
			      C 
			      C IFNDEF GAME_OBJECT_IDS_INC
 = 00000001		      C GAME_OBJECT_IDS_INC EQU 1
			      C 
			      C ; // List of GameObject identifiers
 = 00000000		      C DEFAULT_GAME_OBJECT_ID = 0
			      C 
			      C ENDIF
			      C 
			      C INCLUDE unordered_vector.inc
			      C ; // ==================================
			      C ; // unordered_vector.inc
			      C ; // ----------------------------------
			      C ; // unordered_vector are dynamic arrays of DWORDs
			      C ; // whose contents are not guaranteed to be in the same
			      C ; // order after a removal. They are typically used for 
			      C ; // pools of GameObject pointers whose order doesn't matter.
			      C ; // ==================================
			      C 
			      C IFNDEF UNORDERED_VECTOR_INC
			      C ENDIF
			      C 
			      C INCLUDE component_ids.inc
			      C ; // ==================================
			      C ; // component_ids.inc
			      C ; // ----------------------------------
			      C ; // A set of "enum" style macros that identify component types 
			      C ; // for the data definition and parsing of a scene's data.
			      C ; // ==================================
			      C 
			      C IFNDEF COMPONENT_IDS_INC
 = 00000001		      C COMPONENT_IDS_INC EQU 1
			      C 
			      C ; // A helper function to make defining a bunch of enums smoother
 = 00000000		      C enumId = 0
			      C DEF_ENUM MACRO enum_name
			      C 	enum_name = enumId
			      C 	enumId = enumId + 1
			      C ENDM
			      C 
			      C ENUM_COMPONENT_ID TYPEDEF DWORD
			      C 
			      C ; // List of component identifiers
			      C DEF_ENUM DEFAULT_COMPONENT_ID
			      C DEF_ENUM RECT_COMPONENT_ID
			      C DEF_ENUM SPRITE_COMPONENT_ID
			      C DEF_ENUM TRANSFORM_COMPONENT_ID
			      C 
			      C ENDIF
			      C 
			      C 
			      C ENUM_GAME_OBJECT_ID TYPEDEF DWORD
			      C 
 00000010		      C GameObject_vtable STRUCT
 00000000  00000000	      C 	pStart DWORD ? ; For game logic that should run just after the GameObjec is initialized
 00000004  00000000	      C 	pUpdate DWORD ? ; For game logic that will run every frame update
 00000008  00000000	      C 	pExit DWORD ? ; For game logic that should run just before the GameObject is freed
 0000000C  00000000	      C 	pFree DWORD ? ; Destructor
			      C GameObject_vtable ENDS
			      C 
 00000018		      C GameObject STRUCT
 00000000  00000000	      C 	gameObjectType ENUM_GAME_OBJECT_ID ?
 00000004  00000000	      C 	components UnorderedVector <>
	   00000000
	   00000000
 00000010  00000000	      C 	pVt DWORD ? ; Pointer to a virtual function table
			      C 
			      C 	; // Flags
 00000014  00000000	      C 	awaitingFree DWORD ? ; // Whether the object is awaiting removal from the scene. Zero if FALSE, nonzero if TRUE
			      C GameObject ENDS
			      C 
			      C ; // Static methods
			      C add_component PROTO pGameObject: DWORD, pComponent: DWORD
			      C 
			      C ; // Constructors
			      C init_game_object PROTO maxComponents : DWORD
			      C new_game_object PROTO maxComponents : DWORD
			      C free_game_object PROTO
			      C 
			      C ; // Instance methods
			      C get_first_component_which_is_a	PROTO componentType : ENUM_COMPONENT_ID
			      C game_object_start_virtual		PROTO
			      C game_object_update_virtual		PROTO deltaTime : REAL4
			      C 
			      C ENDIF
			      C 
				INCLUDE game_object_ids.inc
			      C ; // ==================================
			      C ; // game_object_ids.inc
			      C ; // ----------------------------------
			      C ; // A set of "enum" style macros that identify GameObject types 
			      C ; // for the data definition and parsing of a scene's data.
			      C ; //
			      C ; // This is necessary because GameObjects are designed to be
			      C ; // subclassed into new unique types of GameObjects defined
			      C ; // by the user of this engine.
			      C ; // ==================================
			      C 
			      C IFNDEF GAME_OBJECT_IDS_INC
			      C ENDIF
